{
	"info": {
		"_postman_id": "team-selector-auth-v1",
		"name": "Team Selector - Authentication API",
		"description": "Phase 1 Authentication Backend Integration Tests\n\nEndpoints:\n- POST /api/auth/send-otp\n- POST /api/auth/verify-otp\n- POST /api/auth/register\n- POST /api/auth/login\n- POST /api/auth/refresh\n- POST /api/auth/logout",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Send OTP",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Test: Send OTP to valid phone",
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has success field\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('success');",
							"    pm.expect(jsonData.success).to.be.true;",
							"});",
							"",
							"pm.test(\"Response has expiresAt field\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('expiresAt');",
							"    pm.expect(jsonData.expiresAt).to.be.a('string');",
							"});",
							"",
							"pm.test(\"Response has otpCode in dev mode\", function () {",
							"    var jsonData = pm.response.json();",
							"    if (pm.environment.get('NODE_ENV') === 'development') {",
							"        pm.expect(jsonData).to.have.property('otpCode');",
							"        pm.expect(jsonData.otpCode).to.match(/^\\d{6}$/);",
							"        ",
							"        // Save OTP for next request",
							"        pm.environment.set('OTP_CODE', jsonData.otpCode);",
							"        console.log('OTP Code:', jsonData.otpCode);",
							"    }",
							"});",
							"",
							"pm.test(\"ExpiresAt is ~5 minutes in future\", function () {",
							"    var jsonData = pm.response.json();",
							"    var expiresAt = new Date(jsonData.expiresAt);",
							"    var now = new Date();",
							"    var diffMinutes = (expiresAt - now) / (1000 * 60);",
							"    ",
							"    pm.expect(diffMinutes).to.be.greaterThan(4);",
							"    pm.expect(diffMinutes).to.be.lessThan(6);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"phone\": \"{{TEST_PHONE}}\"\n}"
				},
				"url": {
					"raw": "{{BASE_URL}}/api/auth/send-otp",
					"host": ["{{BASE_URL}}"],
					"path": ["api", "auth", "send-otp"]
				},
				"description": "Send OTP code to phone number for signup verification"
			},
			"response": []
		},
