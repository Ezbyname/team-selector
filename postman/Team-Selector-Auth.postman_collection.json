		{
			"name": "4. Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Test: Login with correct credentials",
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has success field\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('success');",
							"    pm.expect(jsonData.success).to.be.true;",
							"});",
							"",
							"pm.test(\"Response has user object\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('user');",
							"    pm.expect(jsonData.user.id).to.equal(pm.environment.get('USER_ID'));",
							"});",
							"",
							"pm.test(\"Response has accessToken\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('accessToken');",
							"    ",
							"    // Save new access token",
							"    pm.environment.set('ACCESS_TOKEN', jsonData.accessToken);",
							"});",
							"",
							"pm.test(\"Set-Cookie header present for refresh_token\", function () {",
							"    pm.expect(pm.response.headers.has('Set-Cookie')).to.be.true;",
							"    var setCookie = pm.response.headers.get('Set-Cookie');",
							"    pm.expect(setCookie).to.include('refresh_token');",
							"    ",
							"    // Extract refresh token for later use",
							"    var match = setCookie.match(/refresh_token=([^;]+)/);",
							"    if (match) {",
							"        pm.environment.set('REFRESH_TOKEN', match[1]);",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
