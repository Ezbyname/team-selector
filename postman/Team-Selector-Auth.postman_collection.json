		{
			"name": "5. Refresh Token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Test: Refresh access token",
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has success field\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('success');",
							"    pm.expect(jsonData.success).to.be.true;",
							"});",
							"",
							"pm.test(\"Response has new accessToken\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('accessToken');",
							"    ",
							"    var oldToken = pm.environment.get('ACCESS_TOKEN');",
							"    pm.expect(jsonData.accessToken).to.not.equal(oldToken);",
							"    ",
							"    // Save new token",
							"    pm.environment.set('ACCESS_TOKEN', jsonData.accessToken);",
							"});",
							"",
							"pm.test(\"Refresh token rotated\", function () {",
							"    var setCookie = pm.response.headers.get('Set-Cookie');",
							"    pm.expect(setCookie).to.include('refresh_token');",
							"    ",
							"    var match = setCookie.match(/refresh_token=([^;]+)/);",
							"    if (match) {",
							"        var oldRefreshToken = pm.environment.get('REFRESH_TOKEN');",
							"        var newRefreshToken = match[1];",
							"        pm.expect(newRefreshToken).to.not.equal(oldRefreshToken);",
							"        pm.environment.set('REFRESH_TOKEN', newRefreshToken);",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
