{
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": "frontend",
  "rewrites": [
    { "source": "/api/auth/(.*)", "destination": "/api/auth/index.js" },
    { "source": "/api/admin/(.*)", "destination": "/api/admin/index.js" },
    { "source": "/api/ratings/(.*)", "destination": "/api/ratings/index.js" },
    { "source": "/api/groups/(.*)", "destination": "/api/groups/index.js" },
    { "source": "/api/players/(.*)", "destination": "/api/players/index.js" },
    { "source": "/api/sessions/(.*)", "destination": "/api/sessions/index.js" },
    { "source": "/", "destination": "/home.html" }
  ]
}
